{
  "name": "token27/nexus-ai-pricing",
  "description": "Financial cost calculation for LLM API usage. Supports token-accurate pricing for OpenAI, Anthropic (with Prompt Caching discounts), Google Gemini, DeepSeek, Groq, Mistral, and more.",
  "type": "library",
  "homepage": "https://github.com/token27/nexus-ai-pricing",
  "authors": [
    {
      "name": "Token27",
      "homepage": "https://github.com/token27",
      "role": "Maintainer"
    },
    {
      "name": "Contributors",
      "homepage": "https://github.com/token27/nexus-ai-pricing/graphs/contributors",
      "role": "Contributor"
    }
  ],
  "keywords": [
    "llm",
    "pricing",
    "openai",
    "anthropic",
    "gemini",
    "deepseek",
    "cost",
    "tokens"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.3"
  },
  "suggest": {
    "token27/nexus-ai-tokenizer": "Required only for estimate()/estimateChat()/estimateWithImages() pre-request estimation. Not needed if you pass token counts from the API response to calculate()."
  },
  "require-dev": {
    "token27/nexus-ai-tokenizer": "^1.0",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Token27\\NexusAI\\Pricing\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Token27\\NexusAI\\Pricing\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit",
    "test:coverage": "phpunit --coverage-text",
    "lint": "php-cs-fixer fix --dry-run --diff",
    "lint-fix": "php-cs-fixer fix",
    "analyse": "phpstan analyse --level=8 src/",
    "check": [
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}